<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/card_bg">

        <!-- Row 0: always LTR order: [emoji+sym] [name] [chg+price] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/emoji0"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:text="🇺🇸" />
                <TextView
                    android:id="@+id/sym0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="USD" />
            </LinearLayout>

            <!-- name: weight=1 fills middle, gravity=start keeps it left-aligned -->
            <TextView
                android:id="@+id/name0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="start"
                android:textAlignment="gravity"
                android:text="US Dollar" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/chg0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />
                <TextView
                    android:id="@+id/price0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1A000000" android:text="" />

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/emoji1"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:text="🇪🇺" />
                <TextView
                    android:id="@+id/sym1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="EUR" />
            </LinearLayout>

            <TextView
                android:id="@+id/name1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="start"
                android:textAlignment="gravity"
                android:text="Euro" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/chg1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />
                <TextView
                    android:id="@+id/price1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1A000000" android:text="" />

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/emoji2"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:text="🥇" />
                <TextView
                    android:id="@+id/sym2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="GOLD" />
            </LinearLayout>

            <TextView
                android:id="@+id/name2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="start"
                android:textAlignment="gravity"
                android:text="Gold 18K" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">
                <TextView
                    android:id="@+id/chg2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />
                <TextView
                    android:id="@+id/price2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/update_time" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone" android:text="" />

    </LinearLayout>
</LinearLayout>
