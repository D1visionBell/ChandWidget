<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/card_bg">

        <!-- ردیف ۰: ستون چپ (emoji+نام) | ستون راست (تغییر+قیمت) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <!-- ستون چپ: emoji بالا، نام پایین — عرض ثابت -->
            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/emoji0"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:text="🇺🇸" />

                <!-- sym مخفی — هنوز باید در layout باشه تا کد Java کرش نکنه -->
                <TextView
                    android:id="@+id/sym0"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:text="USD" />

                <!-- نام نماد زیر آیکون -->
                <TextView
                    android:id="@+id/name0"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:textAlignment="gravity"
                    android:textDirection="firstStrong"
                    android:lineSpacingMultiplier="0.9"
                    android:text="US Dollar" />
            </LinearLayout>

            <!-- فاصله کشسان -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <!-- ستون راست: تغییر + قیمت -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/chg0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />

                <TextView
                    android:id="@+id/price0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1A000000" android:text="" />

        <!-- ردیف ۱ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/emoji1"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:text="🇪🇺" />

                <TextView
                    android:id="@+id/sym1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:text="EUR" />

                <TextView
                    android:id="@+id/name1"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:textAlignment="gravity"
                    android:textDirection="firstStrong"
                    android:lineSpacingMultiplier="0.9"
                    android:text="Euro" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/chg1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />

                <TextView
                    android:id="@+id/price1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1A000000" android:text="" />

        <!-- ردیف ۲ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/emoji2"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:text="🥇" />

                <TextView
                    android:id="@+id/sym2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:text="GOLD" />

                <TextView
                    android:id="@+id/name2"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:textAlignment="gravity"
                    android:textDirection="firstStrong"
                    android:lineSpacingMultiplier="0.9"
                    android:text="Gold 18K" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layoutDirection="ltr">

                <TextView
                    android:id="@+id/chg2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#E53935"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:text="--" />

                <TextView
                    android:id="@+id/price2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:text="---" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/update_time" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone" android:text="" />

    </LinearLayout>
</LinearLayout>
