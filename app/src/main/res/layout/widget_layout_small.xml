<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp"
    android:layoutDirection="ltr"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="9dp"
        android:layoutDirection="ltr"
        android:background="@drawable/card_bg">

        <!-- Header: emoji left + name/sym right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/emoji0"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:textSize="26sp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="🇺🇸" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/name0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textDirection="locale"
                    android:gravity="start"
                    android:text="US Dollar" />
                <TextView
                    android:id="@+id/sym0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textDirection="ltr"
                    android:gravity="start"
                    android:text="USD" />
            </LinearLayout>
        </LinearLayout>

        <!-- Flexible spacer -->
        <TextView android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:text="" />

        <!-- change -->
        <TextView
            android:id="@+id/chg0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#E53935"
            android:layout_marginBottom="2dp"
            android:textDirection="ltr"
            android:gravity="start"
            android:text="↑50" />

        <!-- price — 18sp guarantees full number on 2x2 -->
        <TextView
            android:id="@+id/price0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:textDirection="ltr"
            android:gravity="start"
            android:text="59,750" />

        <TextView android:id="@+id/update_time" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="9sp"
            android:textColor="@color/text_secondary" android:textDirection="ltr"
            android:gravity="start" android:alpha="0.7" android:maxLines="1"
            android:layout_marginTop="2dp" android:text="" />
    </LinearLayout>
</LinearLayout>
