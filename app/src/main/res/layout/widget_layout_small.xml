<?xml version="1.0" encoding="utf-8"?>
<!--
  widget_layout_small.xml  — 2×2 widget, supports 1 or 3 rows
  NOTE: <View> is NOT allowed in RemoteViews (causes InflateException on Samsung/MIUI).
  Use android:layout_weight + Space tag instead (Space is allowed since API 14).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/card_bg">

        <!-- ── SINGLE MODE (slot 0 only, shown large) ─────────────────── -->
        <!-- This container is VISIBLE when rowCount=1, GONE when rowCount=3 -->
        <LinearLayout
            android:id="@+id/single_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Top: emoji + name/symbol -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/emoji0"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:text="🇺🇸" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/name0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="US Dollar" />
                    <TextView
                        android:id="@+id/sym0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:text="USD" />
                </LinearLayout>
            </LinearLayout>

            <!-- Spacer (Space is allowed in RemoteViews) -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Change indicator -->
            <TextView
                android:id="@+id/chg0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:layout_marginBottom="2dp"
                android:text="↑50" />

            <!-- Big price -->
            <TextView
                android:id="@+id/price0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="59,750" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/update_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:text="" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chand"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── MULTI MODE (3 rows, shown compact) ─────────────────────── -->
        <!-- This container is GONE when rowCount=1, VISIBLE when rowCount=3 -->
        <LinearLayout
            android:id="@+id/multi_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Row 0 -->
            <LinearLayout
                android:id="@+id/card0_multi"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/emoji0_m"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:text="🇺🇸" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/sym0_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:text="USD" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/chg0_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="9sp"
                        android:textColor="#E53935"
                        android:gravity="end"
                        android:text="--" />
                    <TextView
                        android:id="@+id/price0_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="end"
                        android:text="---" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:text="" />

            <!-- Row 1 -->
            <LinearLayout
                android:id="@+id/card1_multi"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/emoji1_m"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:text="🇪🇺" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/sym1_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:text="EUR" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/chg1_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="9sp"
                        android:textColor="#E53935"
                        android:gravity="end"
                        android:text="--" />
                    <TextView
                        android:id="@+id/price1_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="end"
                        android:text="---" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:text="" />

            <!-- Row 2 -->
            <LinearLayout
                android:id="@+id/card2_multi"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/emoji2_m"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:text="🥇" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/sym2_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:text="GOLD" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/chg2_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="9sp"
                        android:textColor="#E53935"
                        android:gravity="end"
                        android:text="--" />
                    <TextView
                        android:id="@+id/price2_m"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="end"
                        android:text="---" />
                </LinearLayout>
            </LinearLayout>

            <!-- Chand footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chand"
                android:textSize="8sp"
                android:gravity="end"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
