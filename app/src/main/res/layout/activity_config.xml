<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_config">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── App Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/config_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btn_refresh_app"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/btn_refresh"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/card_bg_config"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/last_update_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- ── Price Grid ── -->
        <LinearLayout
            android:id="@+id/price_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20000000"
            android:layout_marginBottom="20dp" />

        <!-- ── Widget Config Section ── -->
        <LinearLayout
            android:id="@+id/widget_config_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_widget"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="14dp" />

            <!-- Widget size badge -->
            <TextView
                android:id="@+id/widget_size_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/card_bg_config"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:text="@string/widget_size_triple" />

            <!-- Language toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg_config"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/lang_label"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="6dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/lang_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FA"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Multi-row toggle (only shown for small 2×2 widget) -->
            <LinearLayout
                android:id="@+id/multi_row_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg_config"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/multi_row_label"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/multi_row_desc"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/multi_row_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Slot label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/slot_label"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <!-- Slot 0 (always visible) -->
            <LinearLayout
                android:id="@+id/slot0_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />
                <Spinner
                    android:id="@+id/spinner0"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/card_bg_config" />
            </LinearLayout>

            <!-- Slot 1 -->
            <LinearLayout
                android:id="@+id/slot1_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />
                <Spinner
                    android:id="@+id/spinner1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/card_bg_config" />
            </LinearLayout>

            <!-- Slot 2 -->
            <LinearLayout
                android:id="@+id/slot2_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />
                <Spinner
                    android:id="@+id/spinner2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/card_bg_config" />
            </LinearLayout>

            <!-- Save button -->
            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_save"
                android:textSize="16sp"
                android:background="@drawable/btn_save_bg"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
